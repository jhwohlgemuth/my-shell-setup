#! /bin/bash
# shellcheck disable=SC2155
set -e

requires \
    git \
    gum \
    stow

resolve_dotfiles() {
    local DOTFILES_PATH="${GOLD_DOTFILES:-"${HOME}/.dotfiles"}"
    # Stow expects compatible absolute paths for --dir and --target.
    case "${DOTFILES_PATH}" in
        /*)
            printf '%s\n' "${DOTFILES_PATH}"
            ;;
        ~/*)
            printf '%s\n' "${HOME}/${DOTFILES_PATH#~/}"
            ;;
        *)
            printf '%s\n' "${PWD}/${DOTFILES_PATH}"
            ;;
    esac
}
update_gold() {
    local COLOR="${GOLD_FOREGROUND_COLOR:-220}"
    local DOTFILES="$(resolve_dotfiles)"
    local TITLE="Update $(gum style --foreground "${COLOR}" 'Complete')"
    git -C "${DOTFILES}" checkout -- .
    git -C "${DOTFILES}" pull origin main
    stow --dir "${DOTFILES}" --target /usr/local/bin --restow gold
    gum style \
        --border normal \
        --border-foreground "${COLOR}" \
        --margin "1" \
        --padding "1 2" \
        "${TITLE}"
}
update_package() {
    local DOTFILES="$(resolve_dotfiles)"
    stow --dir "${DOTFILES}" --target "${HOME}" --restow "${1}"
}
main() {
    case "${1}" in
        update)
            update_gold
            ;;
        gold)
            update_gold
            ;;
        opencode)
            update_package "opencode"
            ;;
        *)
            echo "Usage: $(basename "${0}") [update|gold|opencode]"
            exit 1
            ;;
    esac
}
main "$@"
