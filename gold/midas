#! /bin/bash
# shellcheck disable=SC2155
set -e

requires \
    git \
    gum \
    stow

resolve_dotfiles() {
    local DOTFILES_PATH="${GOLD_DOTFILES:-"${HOME}/.dotfiles"}"
    # Normalize tilde and relative paths before canonicalization.
    case "${DOTFILES_PATH}" in
        /*)
            ;;
        ~)
            DOTFILES_PATH="${HOME}"
            ;;
        ~/*)
            DOTFILES_PATH="${HOME}/${DOTFILES_PATH#~/}"
            ;;
        *)
            DOTFILES_PATH="${HOME}/${DOTFILES_PATH#./}"
            ;;
    esac
    if [[ ! -d "${DOTFILES_PATH}" ]]; then
        printf 'Error: dotfiles directory not found: %s\n' "${DOTFILES_PATH}" >&2
        return 1
    fi
    # Stow expects compatible absolute paths for --dir and --target.
    REPLY="$(cd "${DOTFILES_PATH}" && pwd -P)"
}
update_gold() {
    local COLOR="${GOLD_FOREGROUND_COLOR:-220}"
    resolve_dotfiles
    local DOTFILES="${REPLY}"
    local TITLE="Update $(gum style --foreground "${COLOR}" 'Complete')"
    git -C "${DOTFILES}" checkout -- .
    git -C "${DOTFILES}" pull origin main
    stow --dir "${DOTFILES}" --target /usr/local/bin --restow gold
    gum style \
        --border normal \
        --border-foreground "${COLOR}" \
        --margin "1" \
        --padding "1 2" \
        "${TITLE}"
}
update_package() {
    resolve_dotfiles
    local DOTFILES="${REPLY}"
    local HOME_DIR="$(cd "${HOME}" && pwd -P)"
    stow --dir "${DOTFILES}" --target "${HOME_DIR}" --restow "${1}"
}
main() {
    case "${1}" in
        update)
            update_gold
            ;;
        gold)
            update_gold
            ;;
        opencode)
            update_package "opencode"
            ;;
        *)
            echo "Usage: $(basename "${0}") [update|gold|opencode]"
            exit 1
            ;;
    esac
}
main "$@"
