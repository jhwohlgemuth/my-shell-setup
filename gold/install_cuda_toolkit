#! /bin/bash
set -e

requires \
    curl \
    zsh
main() {
    local CUDA_HOME_DIR="${1:-/usr/local/cuda}"
    local DEBIAN_VERSION
    local TARGET_HOME
    local ZSHRC
    if [[ -n "${SUDO_USER:-}" ]]; then
        TARGET_HOME="$(getent passwd "${SUDO_USER}" | awk -F: '{print $6}')"
    fi
    TARGET_HOME="${TARGET_HOME:-/home/nonroot}"
    ZSHRC="${TARGET_HOME}/.zshrc"
    DEBIAN_VERSION="$(awk -F= '/^VERSION_ID=/{gsub(/"/, "", $2); split($2, version_parts, "."); print version_parts[1]}' /etc/os-release)"
    curl -fsSL \
        "https://developer.download.nvidia.com/compute/cuda/repos/debian${DEBIAN_VERSION}/x86_64/cuda-keyring_1.1-1_all.deb" \
        -o cuda-keyring_1.1-1_all.deb
    sudo dpkg -i cuda-keyring_1.1-1_all.deb
    rm cuda-keyring_1.1-1_all.deb
    apt-get update
    apt-get install --yes cuda-toolkit
    {
        echo "export CUDA_HOME=${CUDA_HOME_DIR}"
        echo "export PATH=\${CUDA_HOME}/bin:\${PATH}"
        echo "export LD_LIBRARY_PATH=\${CUDA_HOME}/lib64:\${LD_LIBRARY_PATH}"
    } >> "${ZSHRC}"
    printf "\n=> [WARNING] Run 'source %s' or restart your shell to apply PATH changes\n" "${ZSHRC}"
}
main "$@"
