{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "llamacpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama.cpp (local)",
            "options": {
                "baseURL": "http://127.0.0.1:8080/v1"
            },
            "models": {
                "your-model-id": {
                    "name": "Your Model (local)",
                    "limit": {
                        "context": 32768,
                        "output": 8192
                    }
                }
            }
        }
    },
    "model": "llamacpp/your-model-id"
}